{
  "name": "@aeo-seo-radar/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aeo-seo-radar/shared": "*",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.5.0",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
