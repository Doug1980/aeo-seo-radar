# Normaliza fim de linha: no repo sempre LF, evitando ruído de CRLF no Windows.
# Regra padrão para arquivos de texto (autodetecção).
* text=auto eol=lf

# Código e configs — força LF explicitamente.
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Scripts do Windows mantêm CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binários — nunca converter.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
*.lock  binary
